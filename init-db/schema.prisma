generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// TENANT MODELS
// ============================================

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  logoUrl     String?
  website     String?
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String?
  timezone    String   @default("America/Santo_Domingo")
  currency    String   @default("DOP")
  isActive    Boolean  @default(true)
  settings    Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  users       User[]
  contacts    Contact[]
  companies   Company[]
  opportunities Opportunity[]
  activities  Activity[]
  documents   Document[]
  tags        Tag[]
  customFields CustomField[]
  pipelines   Pipeline[]
  auditLogs   AuditLog[]

  // Inventory AI Relations
  inventoryAIConfig InventoryAIConfig?
  warehouses        Warehouse[]
  inventoryItems    InventoryItem[]
  inventoryMovements InventoryMovement[]
  demandForecasts   DemandForecast[]
  productBatches    ProductBatch[]
  inventoryAlerts   InventoryAlert[]
  warehouseMaps     WarehouseMap[]
  suppliers         Supplier[]
  modules           TenantModule[]
  categories        Category[]
  quotes            Quote[]
  invoices          Invoice[]
  subscription      Subscription?
  aiUsageLogs       AIUsageLog[]
  products          Product[]
  invitations       Invitation[]

  @@index([slug])
  @@index([isActive])
  @@map("tenants")
}

// ============================================
// USER & AUTH MODELS
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String
  password      String
  firstName     String
  lastName      String
  avatarUrl     String?
  phone         String?
  jobTitle      String?
  department    String?
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?
  lastLoginIp   String?
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?
  role          UserRole  @default(USER)
  permissions   String[]  @default([])
  preferences   Json?     @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Tenant relation
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  createdContacts    Contact[]    @relation("ContactCreator")
  assignedContacts   Contact[]    @relation("ContactAssignee")
  createdCompanies   Company[]    @relation("CompanyCreator")
  assignedCompanies  Company[]    @relation("CompanyAssignee")
  createdOpportunities Opportunity[] @relation("OpportunityCreator")
  assignedOpportunities Opportunity[] @relation("OpportunityAssignee")
  activities         Activity[]
  createdDocuments   Document[]
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]
  invitationsSent    Invitation[] @relation("InvitationSender")
  invitationsReceived Invitation[] @relation("InvitationRecipient")

  // Inventory Relations
  inventoryMovements InventoryMovement[]
  productBatches     ProductBatch[]
  resolvedAlerts     InventoryAlert[]
  createdProducts    Product[]
  createdWarehouses  Warehouse[]
  createdQuotes      Quote[]    @relation("QuoteCreator")
  createdInvoices    Invoice[]  @relation("InvoiceCreator")

  @@unique([email, tenantId])
  @@index([email])
  @@index([tenantId])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  revokedBy String?
  ipAddress String?
  userAgent String?

  // Relations
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Invitation {
  id        String           @id @default(uuid())
  email     String
  token     String           @unique
  role      UserRole
  expiresAt DateTime
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now())
  acceptedAt DateTime?

  // Relations
  tenantId  String
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy String
  sender    User             @relation("InvitationSender", fields: [invitedBy], references: [id], onDelete: Cascade)
  userId    String?
  recipient User?            @relation("InvitationRecipient", fields: [userId], references: [id], onDelete: SetNull)

  @@unique([email, tenantId])
  @@index([token])
  @@index([tenantId])
  @@index([status])
  @@map("invitations")
}

// ============================================
// CRM CORE MODELS
// ============================================

model Contact {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  jobTitle    String?
  department  String?
  source      LeadSource?
  status      ContactStatus @default(ACTIVE)
  score       Int      @default(0)
  avatarUrl   String?
  address     String?
  city        String?
  country     String?
  birthday    DateTime?
  notes       String?
  customData  Json?    @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // ============================================
  // CREDIT STATUS (Preparación Cuentas por Cobrar)
  // ============================================
  creditStatus     CreditStatus @default(NONE)
  creditLimit      Decimal?     @db.Decimal(15, 2)
  creditBalance    Decimal      @default(0) @db.Decimal(15, 2)
  creditApprovedBy String?
  creditApprovedAt DateTime?
  creditRequestedAt DateTime?
  creditNotes      String?

  // Tenant relation
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // User relations
  createdBy   String
  creator     User     @relation("ContactCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  assignedTo  String?
  assignee    User?    @relation("ContactAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  // Relations
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  opportunities Opportunity[]
  activities  Activity[]
  documents   Document[]
  tags        Tag[]
  quotes      Quote[]
  invoices    Invoice[]

  @@index([tenantId])
  @@index([email])
  @@index([assignedTo])
  @@index([status])
  @@index([companyId])
  @@index([createdAt])
  @@map("contacts")
}

model Company {
  id          String      @id @default(uuid())
  name        String
  legalName   String?
  taxId       String?
  industry    String?
  size        CompanySize?
  type        CompanyType @default(CLIENT)
  website     String?
  email       String?
  phone       String?
  fax         String?
  address     String?
  city        String?
  state       String?
  country     String?
  postalCode  String?
  billingAddress Json?
  shippingAddress Json?
  annualRevenue Decimal?   @db.Decimal(15, 2)
  employees   Int?
  description String?
  logoUrl     String?
  status      CompanyStatus @default(ACTIVE)
  score       Int         @default(0)
  customData  Json?       @default("{}")
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  // Tenant relation
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // User relations
  createdBy   String
  creator     User        @relation("CompanyCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  assignedTo  String?
  assignee    User?       @relation("CompanyAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  // Relations
  contacts    Contact[]
  opportunities Opportunity[]
  activities  Activity[]
  documents   Document[]
  tags        Tag[]
  parentId    String?
  parent      Company?    @relation("CompanyHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  subsidiaries Company[]  @relation("CompanyHierarchy")
  quotes      Quote[]
  invoices    Invoice[]

  @@index([tenantId])
  @@index([name])
  @@index([assignedTo])
  @@index([status])
  @@index([industry])
  @@index([parentId])
  @@map("companies")
}

model Opportunity {
  id          String           @id @default(uuid())
  title       String
  description String?
  value       Decimal          @db.Decimal(15, 2)
  currency    String           @default("DOP")
  
  // AI Scoring Fields
  probability Int              @default(0) // 0-100%
  aiScore     Json?            // { probability, confidenceLevel, factors, suggestedActions, predictedCloseDate, predictedValue }
  aiScoreCalculatedAt DateTime?
  scoreCalculationType String   @default("rules") // 'ai' | 'rules' | 'manual'
  
  // Stage & Status
  stage       OpportunityStage @default(CALIFICAR)
  status      OpportunityStatus @default(OPEN)
  enteredStageAt DateTime      @default(now())
  
  // Dates
  expectedCloseDate DateTime
  actualCloseDate   DateTime?
  
  // Source & Competition
  source      LeadSource?
  lostReason  String?
  competitor  String?
  equipmentBrand String?
  
  // Custom Data
  customData  Json?            @default("{}")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  // Tenant relation
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // User relations
  createdBy   String
  creator     User             @relation("OpportunityCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  assignedTo  String?
  assignee    User?            @relation("OpportunityAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  // Relations
  contactId   String?
  contact     Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId   String?
  company     Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  pipelineId  String?
  pipeline    Pipeline?        @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  stageId     String?
  activities  Activity[]
  documents   Document[]
  tags        Tag[]
  products    OpportunityProduct[]
  scoreHistory OpportunityScoreHistory[]
  quotes      Quote[]
  invoices    Invoice[]

  @@index([tenantId])
  @@index([assignedTo])
  @@index([stage])
  @@index([status])
  @@index([pipelineId])
  @@index([expectedCloseDate])
  @@index([createdAt])
  @@index([companyId])
  @@index([contactId])
  @@map("opportunities")
}

model Pipeline {
  id          String   @id @default(uuid())
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Tenant relation
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  stages      PipelineStage[]
  opportunities Opportunity[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([isDefault])
  @@map("pipelines")
}

model PipelineStage {
  id          String   @id @default(uuid())
  name        String
  description String?
  probability Int      @default(0)
  color       String   @default("#3B82F6")
  order       Int      @default(0)
  isClosed    Boolean  @default(false)
  isWon       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  pipelineId  String
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, name])
  @@index([pipelineId])
  @@index([order])
  @@map("pipeline_stages")
}

// ============================================
// PRODUCT & PRICING MODELS
// ============================================

model Product {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku             String
  name            String
  description     String?
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  type            ProductType @default(PHYSICAL)
  unitOfMeasure   String   @default("unidad")
  barcode         String?
  imageUrl        String?

  // Precios
  averageCost     Decimal  @default(0) @db.Decimal(12, 2)
  salePrice       Decimal? @db.Decimal(12, 2)

  // Stock (solo para PHYSICAL)
  currentStock    Int      @default(0)
  minStock        Int      @default(0)
  maxStock        Int?
  reorderPoint    Int?
  allowNegativeStock Boolean @default(false)

  // Estado
  status          ProductStatus @default(ACTIVE)
  customFields    Json?

  // Auditoría
  createdById     String
  createdBy       User     @relation(fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations
  opportunities OpportunityProduct[]

  // Inventory Relations
  inventoryItems    InventoryItem[]
  inventoryMovements InventoryMovement[]
  demandForecasts   DemandForecast[]
  batches           ProductBatch[]
  inventoryAlerts   InventoryAlert[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId])
  @@map("products")
}

// ============================================
// OPPORTUNITY AI SCORING HISTORY
// ============================================

model OpportunityScoreHistory {
  id              String   @id @default(uuid())
  opportunityId   String
  opportunity     Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  
  score           Int      // 0-100
  probability     Int      // 0-100
  confidenceLevel String   // 'high' | 'medium' | 'low'
  factors         Json     // { positive: [], negative: [] }
  suggestedActions Json   // []
  predictedCloseDate DateTime?
  predictedValue  Decimal? @db.Decimal(15, 2)
  
  calculationType String   // 'ai' | 'rules' | 'manual'
  calculatedById  String?
  
  createdAt       DateTime @default(now())
  
  @@index([opportunityId])
  @@index([createdAt])
  @@map("opportunity_score_history")
}

// ============================================
// QUOTES (COTIZACIONES) - Defined below in full
// ============================================

// ============================================
// OPPORTUNITY PRODUCTS
// ============================================

model OpportunityProduct {
  id          String   @id @default(uuid())
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(15, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2)
  taxRate     Decimal? @db.Decimal(5, 2)
  total       Decimal  @db.Decimal(15, 2)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([productId])
  @@map("opportunity_products")
}

// ============================================
// ACTIVITY & TASK MODELS
// ============================================

model Activity {
  id          String       @id @default(uuid())
  type        ActivityType
  subject     String
  description String?
  status      ActivityStatus @default(PENDING)
  priority    Priority     @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  duration    Int?         // in minutes
  location    String?
  isAllDay    Boolean      @default(false)
  reminderAt  DateTime?
  customData  Json?        @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  // Tenant relation
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // User relation
  createdBy   String
  creator     User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  // Relations
  contactId   String?
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  companyId   String?
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  attendees   ActivityAttendee[]

  @@index([tenantId])
  @@index([createdBy])
  @@index([type])
  @@index([status])
  @@index([dueDate])
  @@index([contactId])
  @@index([companyId])
  @@index([opportunityId])
  @@map("activities")
}

model ActivityAttendee {
  id     String @id @default(uuid())
  name   String
  email  String
  status AttendeeStatus @default(PENDING)

  // Relations
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("activity_attendees")
}

// ============================================
// DOCUMENT MODEL
// ============================================

model Document {
  id          String       @id @default(uuid())
  name        String
  description String?
  fileName    String
  fileType    String
  fileSize    Int
  fileUrl     String
  storagePath String
  category    DocumentCategory @default(OTHER)
  isPrivate   Boolean      @default(false)
  version     Int          @default(1)
  tags        String[]
  customData  Json?        @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  // Tenant relation
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // User relation
  createdBy   String
  creator     User         @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  // Relations
  contactId   String?
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  companyId   String?
  company     Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdBy])
  @@index([category])
  @@index([contactId])
  @@index([companyId])
  @@index([opportunityId])
  @@map("documents")
}

// ============================================
// TAG MODEL
// ============================================

model Tag {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#3B82F6")
  createdAt DateTime @default(now())

  // Tenant relation
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  contacts      Contact[]
  companies     Company[]
  opportunities Opportunity[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("tags")
}

// ============================================
// CUSTOM FIELD MODEL
// ============================================

model CustomField {
  id          String           @id @default(uuid())
  name        String
  label       String
  type        CustomFieldType
  entityType  CustomEntityType
  options     String[]         // for select, multiselect
  isRequired  Boolean          @default(false)
  defaultValue String?
  order       Int              @default(0)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Tenant relation
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entityType, name])
  @@index([tenantId])
  @@index([entityType])
  @@map("custom_fields")
}

// ============================================
// AUDIT LOG MODEL
// ============================================

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String?
  description String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  // Tenant relation
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // User relation
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ContactStatus {
  ACTIVE
  INACTIVE
  CONVERTED
  UNQUALIFIED
}

enum CreditStatus {
  NONE      // Sin solicitud de crédito
  PENDING   // Crédito solicitado, en evaluación
  APPROVED  // Crédito aprobado
  REJECTED  // Crédito rechazado
  SUSPENDED // Crédito suspendido temporalmente
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  PROSPECT
  CUSTOMER
  PARTNER
  COMPETITOR
}

enum CompanySize {
  MICRO      // 1-10
  SMALL      // 11-50
  MEDIUM     // 51-200
  LARGE      // 201-1000
  ENTERPRISE // 1000+
}

enum CompanyType {
  PROSPECT
  CUSTOMER
  PARTNER
  COMPETITOR
  VENDOR
  OTHER
  CLIENT
}

enum OpportunityStage {
  CALIFICAR      // Qualify
  DESARROLLAR    // Develop
  PROPONER       // Propose
  CERRAR         // Close
  CERRADA_GANADA // Closed Won
  CERRADA_PERDIDA // Closed Lost
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  ON_HOLD
  CANCELLED
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  EMAIL
  PHONE
  EVENT
  ADVERTISEMENT
  PARTNER
  COLD_CALL
  OTHER
}

enum ProductType {
  PHYSICAL
  SERVICE
  DIGITAL
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DISCONTINUED
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  TASK
  NOTE
  SMS
  WHATSAPP
  VIDEO_CALL
  SITE_VISIT
  FOLLOW_UP
  REMINDER
}

enum ActivityStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AttendeeStatus {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

enum DocumentCategory {
  CONTRACT
  PROPOSAL
  INVOICE
  RECEIPT
  REPORT
  PRESENTATION
  IMAGE
  VIDEO
  AUDIO
  OTHER
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTISELECT
  TEXTAREA
  URL
  EMAIL
  PHONE
}

enum CustomEntityType {
  CONTACT
  COMPANY
  OPPORTUNITY
  ACTIVITY
}

// ============================================
// INVENTORY AI MODELS
// ============================================

// Configuración de IA por tenant
model InventoryAIConfig {
  id                    String   @id @default(uuid())
  tenantId              String   @unique
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Activación de features
  demandForecasting     Boolean  @default(true)
  expiryTracking        Boolean  @default(true)
  locationOptimization  Boolean  @default(false)
  anomalyDetection      Boolean  @default(true)
  cycleCountAssistant   Boolean  @default(false)

  // Umbrales configurables
  lowStockThreshold     Int      @default(7)
  expiryAlertDays       Int      @default(30)
  anomalySensitivity    String   @default("medium")

  // Proveedor de IA
  aiProvider            String   @default("gemini")
  apiKey                String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("inventory_ai_configs")
}

// Bodegas/Warehouses
model Warehouse {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String
  address     String?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  inventoryItems InventoryItem[]
  movementsFrom  InventoryMovement[] @relation("FromWarehouse")
  movementsTo    InventoryMovement[] @relation("ToWarehouse")
  batches        ProductBatch[]
  map            WarehouseMap?

  @@unique([tenantId, code])
  @@map("warehouses")
}

// Items de inventario (stock por producto y bodega)
model InventoryItem {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity    Int       @default(0)
  location    String?

  @@unique([productId, warehouseId])
  @@map("inventory_items")
}

// Movimientos de inventario
model InventoryMovement {
  id              String           @id @default(uuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId       String
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  type            MovementType
  quantity        Int
  previousStock   Int
  newStock        Int
  unitCost        Decimal?         @db.Decimal(12, 2)

  fromWarehouseId String?
  fromWarehouse   Warehouse?       @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouseId   String?
  toWarehouse     Warehouse?       @relation("ToWarehouse", fields: [toWarehouseId], references: [id])

  referenceType   String?
  referenceId     String?
  referenceNumber String?
  description     String
  reason          String?

  createdById     String
  createdBy       User             @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt       DateTime         @default(now())
  ipAddress       String?
  userAgent       String?

  @@index([tenantId, productId, createdAt])
  @@map("inventory_movements")
}

// Predicciones de demanda (cacheadas)
model DemandForecast {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  forecastDate    DateTime
  predictedDemand Int
  confidence      Float

  factors         Json?

  createdAt       DateTime @default(now())

  @@index([tenantId, productId, forecastDate])
  @@map("demand_forecasts")
}

// Lotes con vencimiento
model ProductBatch {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId     String
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  batchNumber     String
  quantity        Int
  expiryDate      DateTime
  status          BatchStatus @default(ACTIVE)
  receivedAt      DateTime @default(now())
  receivedById    String
  receivedBy      User     @relation(fields: [receivedById], references: [id], onDelete: Cascade)
  alerts          InventoryAlert[]

  @@index([tenantId, expiryDate])
  @@map("product_batches")
}

// Alertas de IA generadas
model InventoryAlert {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type            AlertType
  severity        AlertSeverity
  productId       String?
  product         Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  batchId         String?
  batch           ProductBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  title           String
  description     String
  suggestedAction String
  status          AlertStatus @default(PENDING)
  resolvedAt      DateTime?
  resolvedById    String?
  resolvedBy      User?    @relation(fields: [resolvedById], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([tenantId, status, severity])
  @@map("inventory_alerts")
}

// Mapeo de bodega para optimización
model WarehouseMap {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouseId String    @unique
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  zones       Json
  aisles      Json
  heatmap     Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("warehouse_maps")
}

// Proveedores
model Supplier {
  id          String   @id @default(uuid())
  name        String
  code        String?
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String?
  taxId       String?
  website     String?
  paymentTerms String?
  leadTime    Int?     // días promedio
  isActive    Boolean  @default(true)
  rating      Float?   // 1-5
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Tenant relation
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("suppliers")
}

// ============================================
// INVENTORY MODULE MODELS (Simplified for Canon RD)
// ============================================

enum ModuleCode {
  INVENTORY
  INVOICING_DGII
  COLLECTIONS
  MARKETING
  AI_FEATURES
}

model TenantModule {
  id          String     @id @default(uuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleCode  ModuleCode
  isEnabled   Boolean    @default(false)
  config      Json?
  enabledAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([tenantId, moduleCode])
  @@map("tenant_modules")
}

model Category {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@unique([tenantId, name])
  @@map("categories")
}

// ============================================
// BILLING & SUBSCRIPTION MODELS (SaaS Module)
// ============================================

model Plan {
  id           String         @id @default(uuid())
  code         String         @unique // STARTER, BUSINESS, ENTERPRISE
  name         String
  description  String?
  priceMonthly Float
  priceYearly  Float
  maxUsers     Int            @default(5)
  maxAdmins    Int            @default(1)
  maxStorageGB Int            @default(5)
  features     String[] // Lista de funcionalidades incluidas
  subscriptions Subscription[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Subscription {
  id              String             @id @default(uuid())
  tenantId        String             @unique
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  planId          String
  plan            Plan               @relation(fields: [planId], references: [id])
  status          SubscriptionStatus @default(ACTIVE)
  billingCycle    BillingCycle       @default(MONTHLY)
  startDate       DateTime           @default(now())
  nextPaymentDate DateTime
  lastPaymentDate DateTime?
  cancelAtPeriodEnd Boolean          @default(false)
  externalId      String?            // ID de suscripción en Stripe/PayPal
  paymentMethod   String?            // STRIPE, PAYPAL, AZUL, etc.
  paymentLogs     PaymentLog[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model PaymentLog {
  id             String        @id @default(uuid())
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  tenantId       String
  amount         Float
  currency       String        @default("DOP")
  status         PaymentStatus
  gateway        String        // STRIPE, AZUL, etc.
  gatewayRef     String?       // ID de transacción externo
  paidAt         DateTime?
  invoiceUrl     String?       // Link al PDF generado
  metadata       Json?
  createdAt      DateTime      @default(now())
}

model GlobalBillingConfig {
  id           String   @id @default("default")
  stripeActive Boolean  @default(false)
  paypalActive Boolean  @default(false)
  azulActive   Boolean  @default(false)
  dlocalActive Boolean  @default(false)
  tpagoActive  Boolean  @default(false)
  currency     String   @default("DOP")
  taxRate      Float    @default(18.0)
  updatedAt    DateTime @updatedAt
}

// ============================================
// ANTÜ AI CORE - Gestión de Inteligencia
// ============================================

model AIProviderConfig {
  id           String   @id // GEMINI, OPENAI, ANTHROPIC, KIMI
  name         String
  isActive     Boolean  @default(false)
  apiKey       String   // Almacenada cifrada (AES-256)
  modelName    String   // Ej: gpt-4, claude-3, gemini-1.5-pro
  baseUrl      String?  // Para endpoints personalizados
  settings     Json?    // temp, maxTokens, etc.
  updatedAt    DateTime @updatedAt
}

model PromptTemplate {
  id           String   @id // PREDICCION_VENTAS, ASISTENTE_MARKETING, etc.
  module       String   // SALES, MARKETING, BILLING
  name         String
  systemPrompt String   @db.Text
  userPrompt   String   @db.Text
  version      Int      @default(1)
  updatedAt    DateTime @updatedAt
}

model AIUsageLog {
  id               String   @id @default(uuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  provider         String   // GEMINI, OPENAI, etc.
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCost    Float    @default(0.0)
  action           String   // Tipo de tarea: ANALISIS_DATOS, PREDICTION, etc.
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  GRACE_PERIOD
  UNPAID
  CANCELED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ============================================
// INVENTORY ENUMS (Originales)
// ============================================

enum MovementType {
  PURCHASE
  SALE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN_IN
  RETURN_OUT
  DAMAGED
  EXPIRED
  INITIAL
  PRODUCTION_IN
  PRODUCTION_OUT
}

enum BatchStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  QUARANTINE
  DISPOSED
}

enum AlertType {
  LOW_STOCK
  STOCKOUT_RISK
  EXPIRY_WARNING
  EXPIRED
  ANOMALY_DETECTED
  OVERSTOCK
  SLOW_MOVING
  RECOMMEND_REORDER
  LOCATION_OPTIMIZE
}

enum AlertSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  PENDING
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  DISMISSED
}

// ============================================
// QUOTE MODELS
// ============================================

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

model Quote {
  id              String      @id @default(uuid())
  quoteNumber     String      // COT-001-2026
  title           String
  description     String?
  status          QuoteStatus @default(DRAFT)
  
  // Amounts (DOP)
  subtotal        Decimal     @db.Decimal(15, 2) @default(0)
  taxRate         Decimal     @db.Decimal(5, 2)  @default(18)  // ITBIS 18%
  taxAmount       Decimal     @db.Decimal(15, 2) @default(0)
  discountPercent Decimal     @db.Decimal(5, 2)  @default(0)
  discountAmount  Decimal     @db.Decimal(15, 2) @default(0)
  total           Decimal     @db.Decimal(15, 2) @default(0)
  currency        String      @default("DOP")
  
  // Dates
  issueDate       DateTime    @default(now())
  validUntil      DateTime
  
  // Notes
  notes           String?
  termsAndConditions String?
  
  // Relations
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opportunityId   String?
  opportunity     Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  companyId       String?
  company         Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId       String?
  contact         Contact?    @relation(fields: [contactId], references: [id], onDelete: SetNull)
  createdBy       String
  creator         User        @relation("QuoteCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  
  // Items
  items           QuoteItem[]
  
  // Invoice link
  invoices        Invoice[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
  @@index([opportunityId])
  @@index([companyId])
  @@index([status])
  @@map("quotes")
}

model QuoteItem {
  id              String   @id @default(uuid())
  quoteId         String
  quote           Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  
  // Product info (denormalized for quote snapshot)
  sku             String?
  name            String
  description     String?
  quantity        Int      @default(1)
  unitPrice       Decimal  @db.Decimal(15, 2)
  discountPercent Decimal  @db.Decimal(5, 2) @default(0)
  discountAmount  Decimal  @db.Decimal(15, 2) @default(0)
  subtotal        Decimal  @db.Decimal(15, 2)
  taxAmount       Decimal  @db.Decimal(15, 2) @default(0)
  total           Decimal  @db.Decimal(15, 2)
  
  // Delivery
  availability    String?
  deliveryTime    String?
  
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([quoteId])
  @@map("quote_items")
}

// ============================================
// INVOICE MODELS (Facturación Comercial)
// ============================================

enum InvoiceStatus {
  DRAFT
  PENDING       // Enviada, pendiente de pago
  PARTIAL       // Parcialmente pagada
  PAID          // Pagada
  OVERDUE       // Vencida
  CANCELLED     // Anulada
  CREDIT_NOTE   // Nota de crédito
}

enum PaymentMethod {
  CASH
  CHECK
  BANK_TRANSFER
  CREDIT_CARD
  CREDIT         // Crédito del cliente
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        // FACT-001-2026
  ncf             String?       // Número Comprobante Fiscal (RD)
  title           String?
  status          InvoiceStatus @default(DRAFT)
  
  // Amounts
  subtotal        Decimal       @db.Decimal(15, 2) @default(0)
  taxRate         Decimal       @db.Decimal(5, 2)  @default(18)
  taxAmount       Decimal       @db.Decimal(15, 2) @default(0)
  discountPercent Decimal       @db.Decimal(5, 2)  @default(0)
  discountAmount  Decimal       @db.Decimal(15, 2) @default(0)
  total           Decimal       @db.Decimal(15, 2) @default(0)
  paidAmount      Decimal       @db.Decimal(15, 2) @default(0)
  balance         Decimal       @db.Decimal(15, 2) @default(0)
  currency        String        @default("DOP")
  
  // Payment
  paymentMethod   PaymentMethod?
  paymentTermsDays Int          @default(30)
  
  // Dates
  issueDate       DateTime      @default(now())
  dueDate         DateTime
  paidAt          DateTime?
  
  // Notes
  notes           String?
  
  // Relations
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId       String?
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactId       String?
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId   String?
  opportunity     Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  quoteId         String?
  quote           Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  createdBy       String
  creator         User          @relation("InvoiceCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  
  // Items
  items           InvoiceItem[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([companyId])
  @@index([status])
  @@index([dueDate])
  @@index([opportunityId])
  @@map("invoices")
}

model InvoiceItem {
  id              String   @id @default(uuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  sku             String?
  name            String
  description     String?
  quantity        Int      @default(1)
  unitPrice       Decimal  @db.Decimal(15, 2)
  discountPercent Decimal  @db.Decimal(5, 2) @default(0)
  discountAmount  Decimal  @db.Decimal(15, 2) @default(0)
  subtotal        Decimal  @db.Decimal(15, 2)
  taxAmount       Decimal  @db.Decimal(15, 2) @default(0)
  total           Decimal  @db.Decimal(15, 2)
  
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_items")
}
