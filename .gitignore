# ================================================
# ANTU CRM - Git Ignore
# ================================================

# ================================================
# SECURITY - NUNCA subir estos archivos
# ================================================
.env
.env.local
.env.production
.env.staging
*.pem
*.key
*.cert
secrets/
config/secrets/

# ================================================
# Dependencies
# ================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ================================================
# Build outputs
# ================================================
dist/
build/
*.tsbuildinfo
.next/
out/

# ================================================
# Logs
# ================================================
logs/
*.log
logs/*.log
api/logs/

# ================================================
# Runtime data
# ================================================
pids/
*.pid
*.seed
*.pid.lock

# ================================================
# Testing
# ================================================
coverage/
.nyc_output/

# ================================================
# IDEs and editors
# ================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ================================================
# Uploads and temporary files
# ================================================
uploads/
temp/
tmp/
*.tmp

# ================================================
# Docker
# ================================================
.dockerignore
docker-compose.override.yml

# ================================================
# Database
# ================================================
*.dump
*.backup
*.sql
database/backups/

# ================================================
# Misc
# ================================================
.cache/
.eslintcache
.parcel-cache/
