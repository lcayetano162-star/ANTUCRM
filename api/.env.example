# ================================================
# ANTU CRM API - Environment Variables Example
# ================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)
# ================================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/antucrm

# JWT Configuration
JWT_SECRET=your-jwt-secret-here-minimum-32-characters-long
JWT_EXPIRES_IN=24h

# Encryption Key (32 characters)
ENCRYPTION_KEY=your-encryption-key-32-char-long

# Server
NODE_ENV=development
PORT=3001

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Super Admin (for initial setup)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=changeme-strong-password

# Optional: APIs
GEMINI_API_KEY=
OPENAI_API_KEY=
RESEND_API_KEY=
WEBHOOK_SECRET=

# Email Worker
EMAIL_WORKER_ENABLED=false
