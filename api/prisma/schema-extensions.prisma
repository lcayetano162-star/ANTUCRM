// ============================================
// EXTENSIONES AL SCHEMA - Modelos Completos
// Agregar al final de schema.prisma
// ============================================

// ============================================
// MODELOS DE INTERACTIONS (ACTUALIZADOS)
// ============================================

model InteractionEvent {
  id            String   @id @default(uuid())
  interactionId String
  tenantId      String
  eventType     String
  eventData     Json?
  provider      String   @default("unknown")
  createdAt     DateTime @default(now())

  @@index([interactionId])
  @@index([tenantId, createdAt])
  @@map("interaction_events")
}

// ============================================
// MODELOS DE WHATSAPP (ACTUALIZADOS)
// ============================================

model WhatsAppConfig {
  id                  String    @id @default(uuid())
  tenantId            String    @unique
  phoneNumberId       String
  businessAccountId   String?
  accessToken         String
  appSecret           String?
  webhookVerifyToken  String?
  isActive            Boolean   @default(true)
  isVerified          Boolean   @default(false)
  messagesSentToday   Int       @default(0)
  messagesSentDate    String?
  connectedAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("whatsapp_configs")
}

