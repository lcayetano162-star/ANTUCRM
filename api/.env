# ============================================
# ANTU CRM - Configuración de Entorno
# ============================================

# Servidor
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Base de Datos
DATABASE_URL="file:./dev.db"

# JWT - Generar con scripts/generate-keys.ts
JWT_PRIVATE_KEY_
JWT_PUBLIC_KEY_
JWT_EXPIRATION=8h

# Google Gemini AI
GEMINI_API_KEY=

# Configuración de Tenant
DEFAULT_TENANT_ID=

# Logging
LOG_LEVEL=debug
