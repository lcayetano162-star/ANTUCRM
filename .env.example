# ================================================
# ANTU CRM — Plantilla de Configuración
# ================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env: cp .env.example .env
# 2. Genera valores seguros (ver comentarios)
# 3. NUNCA subas .env a Git (ya está en .gitignore)
# ================================================

# ================================================
# BASE DE DATOS (REQUERIDO)
# ================================================
# PostgreSQL connection string
# Ejemplo: postgresql://user:pass@host:port/db?sslmode=require
DATABASE_URL=REEMPLAZA_CON_TU_CONNECTION_STRING

# ================================================
# SEGURIDAD CRÍTICA (REQUERIDO)
# ================================================
# Generar con: openssl rand -hex 32
# Debe ser EXACTAMENTE 32 caracteres para ENCRYPTION_KEY
JWT_SECRET=REEMPLAZA_CON_64_CARACTERES_ALEATORIOS
ENCRYPTION_KEY=REEMPLAZA_CON_32_CARACTERES_EXACTOS

# Expiración de tokens
JWT_EXPIRES_IN=24h

# ================================================
# SUPER ADMIN (REQUERIDO)
# ================================================
# Credenciales del Super Admin inicial
# Usar email real y contraseña segura
SUPER_ADMIN_EMAIL=REEMPLAZA_CON_EMAIL_REAL
SUPER_ADMIN_PASSWORD=REEMPLAZA_CON_PASSWORD_SEGURO

# ================================================
# SERVIDOR
# ================================================
NODE_ENV=production
PORT=3001
API_URL=https://REEMPLAZA_CON_TU_DOMINIO_O_IP

# ================================================
# FRONTEND
# ================================================
CORS_ORIGIN=https://REEMPLAZA_DOMINIO,http://localhost:5173
FRONTEND_URL=https://REEMPLAZA_DOMINIO

# ================================================
# APIS EXTERNAS (OPCIONAL SEGÚN MÓDULOS)
# ================================================

# OpenAI / Anthropic (Coach IA, Análisis de emails)
OPENAI_API_KEY=sk-REEMPLAZA_CON_TU_API_KEY

# Google Gemini (alternativa para Coach IA)
GEMINI_API_KEY=REEMPLAZA_CON_TU_API_KEY

# SendGrid / Resend (Emails transaccionales)
RESEND_API_KEY=re_REEMPLAZA_CON_TU_API_KEY
SENDGRID_API_KEY=SG.REEMPLAZA_CON_TU_API_KEY

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=REEMPLAZA_CON_TOKEN
WHATSAPP_PHONE_NUMBER_ID=REEMPLAZA_CON_PHONE_ID
WHATSAPP_WEBHOOK_VERIFY_TOKEN=REEMPLAZA_CON_TOKEN_SEGURO

# ================================================
# WEBHOOKS (REQUERIDO PARA INBOUND EMAILS)
# ================================================
# Generar con: openssl rand -hex 32
WEBHOOK_SECRET=REEMPLAZA_CON_64_CARACTERES_ALEATORIOS

# ================================================
# EMAIL SMTP (OPCIONAL)
# ================================================
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=REEMPLAZA_CON_API_KEY
EMAIL_FROM_EMAIL=noreply@REEMPLAZA_DOMINIO
EMAIL_FROM_NAME=Antu CRM

# ================================================
# MONITOREO (OPCIONAL)
# ================================================
SENTRY_DSN=REEMPLAZA_CON_TU_DSN
LOG_LEVEL=info

# ================================================
# FEATURE FLAGS
# ================================================
EMAIL_WORKER_ENABLED=true
