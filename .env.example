# ============================================
# ANTU CRM - Environment Configuration
# ============================================

# Application
NODE_ENV=development
PORT=3000
APP_NAME=ANTU CRM
APP_VERSION=1.0.0
API_PREFIX=api
API_VERSION=v1

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/antu_crm?schema=public"

# JWT Configuration
# Path to RSA keys for RS256 signing
SECRETS_PATH=/secrets
JWT_ALGORITHM=RS256
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Security
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
SESSION_TIMEOUT=900
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=3600

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_CREDENTIALS=true

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DEST=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@antu.crm

# Storage (AWS S3 or compatible)
STORAGE_DRIVER=local
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_ENDPOINT=

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Features
ENABLE_AUDIT_LOG=true
ENABLE_NOTIFICATIONS=true
ENABLE_WEBHOOKS=true
ENABLE_ANALYTICS=true

# AI / Gemini
GEMINI_API_KEY=your-gemini-api-key-here

# Canon RD Specific
CANON_RD_TAX_ID_FORMAT=\d{3}-\d{7}-\d{1}
CANON_RD_PHONE_FORMAT=\(809\) \d{3}-\d{4}
CANON_RD_CURRENCY=DOP
CANON_RD_TIMEZONE=America/Santo_Domingo
